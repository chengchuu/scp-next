{
  "defaultProfile": "production",
  "profiles": {
    "production": {
      "host": "production.example.com",
      "username": "deploy",
      "privateKeyFile": "~/.ssh/id_ed25519"
    }
  },
  "jobs": {
    "deploy": {
      "operation": "upload",
      "profile": "production",
      "source": "./dist",
      "destination": "/var/www/example",
      "recursive": true,
      "overwrite": true,
      "createDirectories": true,
      "postUploadCommands": [
        "cd /var/www/example && npm install --omit=dev",
        "pm2 reload example"
      ]
    }
  }
}
